# JobRadar Backend Environment Variables
# Copy this to .env and fill in your values

# Flask
FLASK_ENV=development
SECRET_KEY=dafsagbsjafs-bjfdkgbs-qqhurqcb

# Database (leave empty for local SQLite)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Custom Search API (free: 100 queries/day)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Bing Web Search API (free: 1000 queries/month)
# Get yours at: https://portal.azure.com
BING_API_KEY=

# Frontend URL (for CORS)
